            "vkGetDeviceProcAddr": "vkGetDeviceProcAddr"
        },
        "instance_extensions": [],
        "device_extensions": [],
        "enable_environment": {
            "AURORA_MALI_SANITIZER_ENABLE": "1"
        },
        "disable_environment": {
            "AURORA_MALI_SANITIZER_DISABLE": "1"
        }
    }
}
